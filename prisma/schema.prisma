// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String
  role          String    @default("USUARIO") // USUARIO, SUPORTE, ADMIN
  mustChangePassword Boolean @default(false)
  theme         String    @default("light") // light, dark
  cpf           String?   @unique
  funcao        String?
  setor         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  ticketsSolicitados Ticket[]  @relation("TicketSolicitante")
  ticketsAtribuidos  Ticket[]  @relation("TicketResponsavel")
  chamadosSecundarios Ticket[] @relation("TicketTecnicosSecundarios")
  comments           Comment[]
  auditLogs          AuditLog[]
  notifications      Notification[]
}

model Ticket {
  id            String    @id @default(cuid())
  titulo        String
  descricao     String
  categoria     String    // Hardware, Software, Rede/Internet, Dúvida, Acessos
  status        String    @default("ABERTO") // ABERTO, EM_ANDAMENTO, PENDENTE_USUARIO, RESOLVIDO
  prioridade    String    @default("BAIXA")  // BAIXA, MEDIA, ALTA, CRITICA
  
  // Solicitante contacts
  departamento  String?
  contatoOpcional String? // Telefone/Ramal
  paraOutraPessoa Boolean @default(false)
  aguardandoReabertura Boolean @default(false)
  encerradoPeloAutor Boolean @default(false)
  
  solicitanteId String
  solicitante   User      @relation("TicketSolicitante", fields: [solicitanteId], references: [id])
  
  responsavelId String?
  responsavel   User?     @relation("TicketResponsavel", fields: [responsavelId], references: [id])
  
  tecnicosSecundarios User[] @relation("TicketTecnicosSecundarios")
  
  notaAvaliacao       Int?
  comentarioAvaliacao String?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  comments      Comment[]
  auditLogs     AuditLog[]
  attachments   Attachment[]
  notifications Notification[]
}

model Comment {
  id            String    @id @default(cuid())
  texto         String
  isInterno     Boolean   @default(false)
  isSolucao     Boolean   @default(false)
  
  ticketId      String
  ticket        Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  
  autorId       String
  autor         User      @relation(fields: [autorId], references: [id])
  
  createdAt     DateTime  @default(now())
  attachments   Attachment[]
}

model Attachment {
  id          String   @id @default(cuid())
  fileName    String
  fileUrl     String
  fileSize    Int
  mimeType    String
  
  ticketId    String?
  ticket      Ticket?  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  
  commentId   String?
  comment     Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
}

model AuditLog {
  id            String    @id @default(cuid())
  acao          String    // ABERTURA, MUDANCA_STATUS, COMENTARIO, ATRIBUICAO, FECHAMENTO
  detalhes      String?   // Ex: 'Status alterado de ABERTO para EM_ANDAMENTO'
  
  ticketId      String
  ticket        Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  
  userId        String?
  user          User?     @relation(fields: [userId], references: [id])
  
  createdAt     DateTime  @default(now())
}

model Category {
  id               String   @id @default(cuid())
  nome             String   @unique
  prioridadePadrao String   @default("BAIXA") // BAIXA, MEDIA, ALTA, CRITICA
  ativo            Boolean  @default(true)
  placeholder      String?  // Texto instrucional opcional mostrado na hora de criar o ticket
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  mensagem  String
  lida      Boolean  @default(false)
  link      String?
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  ticketId  String?
  ticket    Ticket?  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
}
