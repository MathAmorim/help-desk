generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String         @id @default(cuid())
  name                String?
  email               String?        @unique
  password            String
  role                String         @default("USUARIO")
  mustChangePassword  Boolean        @default(false)
  theme               String         @default("light")
  cpf                 String?        @unique
  funcao              String?
  setor               String?
  ativo               Boolean        @default(true)
  deletedAt           DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  searchVector        String?
  attachments         Attachment[]
  auditLogs           AuditLog[]
  comments            Comment[]
  notifications       Notification[]
  snakeScores         SnakeScore[]
  ticketsAtribuidos   Ticket[]       @relation("TicketResponsavel")
  ticketsSolicitados  Ticket[]       @relation("TicketSolicitante")
  chamadosSecundarios Ticket[]       @relation("TicketTecnicosSecundarios")
  announcements       Announcement[] @relation("AnnouncementCreator")
}

model Ticket {
  id                   String         @id @default(cuid())
  titulo               String
  descricao            String
  categoria            String
  status               String         @default("ABERTO")
  prioridade           String         @default("BAIXA")
  departamento         String?
  contatoOpcional      String?
  paraOutraPessoa      Boolean        @default(false)
  aguardandoReabertura Boolean        @default(false)
  encerradoPeloAutor   Boolean        @default(false)
  solicitanteId        String
  responsavelId        String?
  notaAvaliacao        Int?
  comentarioAvaliacao  String?
  dataAssuncao         DateTime?
  dataResolucao        DateTime?
  dataFechamento       DateTime?
  vencimentoSLA        DateTime?
  ultimoPausa          DateTime?
  totalPausado         Int            @default(0)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  searchVector         String?
  attachments          Attachment[]
  auditLogs            AuditLog[]
  comments             Comment[]
  notifications        Notification[]
  responsavel          User?          @relation("TicketResponsavel", fields: [responsavelId], references: [id])
  solicitante          User           @relation("TicketSolicitante", fields: [solicitanteId], references: [id])
  tecnicosSecundarios  User[]         @relation("TicketTecnicosSecundarios")
}

model Comment {
  id          String       @id @default(cuid())
  texto       String
  isInterno   Boolean      @default(false)
  isSolucao   Boolean      @default(false)
  ticketId    String
  autorId     String
  createdAt   DateTime     @default(now())
  attachments Attachment[]
  autor       User         @relation(fields: [autorId], references: [id])
  ticket      Ticket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model Attachment {
  id        String   @id @default(cuid())
  fileName  String
  fileUrl   String
  fileSize  Int
  mimeType  String
  userId    String?
  ticketId  String?
  commentId String?
  createdAt DateTime @default(now())
  comment   Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  ticket    Ticket?  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id])
}

model AuditLog {
  id        String   @id @default(cuid())
  acao      String
  detalhes  String?
  ticketId  String?
  userId    String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
  ticket    Ticket?  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model Category {
  id               String   @id @default(cuid())
  nome             String   @unique
  prioridadePadrao String   @default("BAIXA")
  ativo            Boolean  @default(true)
  placeholder      String?
  tempoResolucao   Int      @default(72)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  mensagem  String
  lida      Boolean  @default(false)
  link      String?
  userId    String
  ticketId  String?
  createdAt DateTime @default(now())
  ticket    Ticket?  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SnakeScore {
  id        String   @id @default(cuid())
  score     Int
  userId    String?
  guestName String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Setting {
  id                   String   @id @default("global")
  tempoMaximoAssuncao  Int      @default(24)
  tempoMaximoConclusao Int      @default(72)
  updatedAt            DateTime @updatedAt
}

model Announcement {
  id        String    @id @default(cuid())
  title     String
  content   String
  severity  String    @default("INFO") // INFO, WARNING, CRITICAL
  active    Boolean   @default(true)
  expiresAt DateTime?
  userId    String
  creator   User      @relation("AnnouncementCreator", fields: [userId], references: [id])
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
}
